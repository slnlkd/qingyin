page {
  min-height: 100%;
  background: linear-gradient(180deg, #f4faf6 0%, #eef6f1 100%);
  color: #111827;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  padding: 24rpx 24rpx 40rpx;
}

.hero-card,
.panel-card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(194, 229, 207, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(34, 197, 94, 0.08);
  backdrop-filter: blur(16rpx);
}

.hero-card {
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

.primary-button {
  height: 84rpx;
  border-radius: 999rpx;
  border: 0;
  background: linear-gradient(135deg, #69d39c 0%, #4db879 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.secondary-button {
  height: 76rpx;
  border-radius: 999rpx;
  border: 1rpx solid #cdebd8;
  background: #ffffff;
  color: #1f7a49;
  font-size: 28rpx;
}

.ghost-button {
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d5e8dc;
  background: #f8fcf9;
  color: #1f7a49;
  font-size: 24rpx;
  line-height: 68rpx;
}

.actions-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.actions-row button {
  flex: 1;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #effaf3;
  color: #1f7a49;
  font-size: 24rpx;
  line-height: 1;
}

.status-chip.warn {
  background: #fff3f2;
  color: #d14d41;
}

.status-chip.neutral {
  background: #f3f4f6;
  color: #4b5563;
}

.panel-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  padding: 24rpx 16rpx;
  border-radius: 24rpx;
  background: #f8fcf9;
  border: 1rpx solid #d9eee2;
}

.stat-label {
  font-size: 24rpx;
  color: #4b5563;
}

.stat-value {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.1;
}

.stat-value.small {
  font-size: 34rpx;
}

.field-row,
.group-row,
.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.field-row,
.group-row {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf3ef;
}

.field-row:last-child,
.group-row:last-child {
  border-bottom: 0;
}

.field-label,
.group-label {
  font-size: 25rpx;
  color: #6b7280;
}

.field-value,
.group-value {
  font-size: 27rpx;
  color: #111827;
  text-align: right;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.member-row {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f9fcfa;
  border: 1rpx solid #e1efe6;
}

.member-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.member-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf9f1;
  font-size: 32rpx;
}

.member-text {
  min-width: 0;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
}

.member-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.member-status {
  flex-shrink: 0;
}

.muted-text {
  font-size: 25rpx;
  color: #6b7280;
  line-height: 1.7;
}

.error-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #d14d41;
}

.empty-state {
  padding: 18rpx 0 6rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.quick-action-card {
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid #deefe4;
  background: #f8fcf9;
}

.quick-action-title {
  font-size: 28rpx;
  font-weight: 700;
}

.quick-action-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.checkin-ring-card {
  text-align: center;
}

.checkin-date {
  font-size: 24rpx;
  color: #6b7280;
}

.checkin-ring {
  width: 280rpx;
  height: 280rpx;
  margin: 28rpx auto 24rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, rgba(255,255,255,0.96) 0%, rgba(227,247,235,0.98) 45%, rgba(113,210,154,0.26) 70%, rgba(91,194,136,0.14) 100%);
  border: 16rpx solid rgba(120, 213, 161, 0.55);
  box-shadow:
    0 18rpx 40rpx rgba(34, 197, 94, 0.14),
    inset 0 0 0 14rpx rgba(255, 255, 255, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-ring.done {
  border-color: rgba(103, 208, 148, 0.92);
  box-shadow:
    0 22rpx 46rpx rgba(34, 197, 94, 0.16),
    0 0 42rpx rgba(103, 208, 148, 0.2),
    inset 0 0 0 14rpx rgba(255, 255, 255, 0.84);
}

.checkin-ring-inner {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(232,249,239,0.96) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 26rpx rgba(34, 197, 94, 0.1);
}

.checkin-mark {
  font-size: 54rpx;
  line-height: 1;
}

.checkin-title {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.checkin-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.mood-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
}

.mood-chip {
  min-height: 108rpx;
  padding: 16rpx 8rpx;
  border-radius: 22rpx;
  border: 1rpx solid #d8ebe0;
  background: #fbfdfb;
  text-align: center;
  box-sizing: border-box;
}

.mood-chip.active {
  border-color: #6dcf99;
  background: linear-gradient(180deg, #f2fff7 0%, #e8f8ef 100%);
  box-shadow: 0 10rpx 18rpx rgba(34, 197, 94, 0.08);
}

.mood-emoji {
  font-size: 34rpx;
  line-height: 1;
}

.mood-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #374151;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #d8ebe0;
  background: #fbfdfb;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
}

.hint-text {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.7;
}

.group-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.inline-button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.inline-button-row button {
  flex: 1;
}

.right-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-card {
  padding: 28rpx 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #374151;
}

.form-input,
.form-picker {
  width: 100%;
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #d8ebe0;
  background: #fbfdfb;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
}

.form-picker {
  display: flex;
  align-items: center;
}

.form-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7280;
}
