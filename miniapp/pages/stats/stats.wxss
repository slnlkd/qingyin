.trend-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trend-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid #deefe4;
  background: #f8fcf9;
}

.trend-day,
.trend-mood {
  font-size: 26rpx;
}

.trend-day {
  color: #6b7280;
}

.trend-mood {
  font-weight: 600;
  color: #1f7a49;
}

.calendar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: 700;
}

.calendar-switch {
  flex: 0 0 auto;
}

.calendar-week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
}

.calendar-week-row {
  margin-bottom: 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: #6b7280;
}

.calendar-cell {
  min-height: 64rpx;
  border-radius: 18rpx;
  background: #fbfdfb;
  border: 1rpx solid #e3efe8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calendar-cell.is-empty {
  border-color: transparent;
  background: transparent;
}

.calendar-cell.is-checked {
  background: linear-gradient(180deg, #f1fff6 0%, #dff7e9 100%);
  border-color: #87dcb0;
  box-shadow: 0 10rpx 18rpx rgba(34, 197, 94, 0.08);
}

.calendar-day {
  font-size: 24rpx;
  font-weight: 600;
}
