.home-hero-card {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(183, 235, 204, 0.48) 0%, rgba(183, 235, 204, 0.08) 30%, transparent 55%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(241, 250, 245, 0.96) 100%);
}

.home-hero-card::before,
.home-hero-card::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.home-hero-card::before {
  width: 220rpx;
  height: 220rpx;
  right: -76rpx;
  top: -90rpx;
  background: rgba(144, 216, 176, 0.14);
}

.home-hero-card::after {
  width: 168rpx;
  height: 168rpx;
  left: -54rpx;
  bottom: -60rpx;
  background: rgba(111, 206, 152, 0.08);
}

.home-hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.home-eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #4fa16f;
}

.home-auth-chip {
  flex-shrink: 0;
}

.home-hero-subtitle {
  max-width: 88%;
}

.home-bind-message {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
}

.home-hero-stats {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
}

.hero-stat-item {
  background: rgba(248, 252, 249, 0.88);
  border-color: rgba(194, 229, 207, 0.92);
  box-shadow: 0 10rpx 22rpx rgba(34, 197, 94, 0.06);
}

.hero-stat-item .stat-label {
  color: #547160;
}

.home-quick-panel {
  padding-bottom: 28rpx;
}

.home-quick-actions {
  margin-top: 6rpx;
}

.home-quick-card {
  position: relative;
  overflow: hidden;
  min-height: 176rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 251, 247, 0.94) 100%);
}

.home-quick-card::after {
  content: "";
  position: absolute;
  right: -24rpx;
  top: -24rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(111, 206, 152, 0.1);
}

.home-quick-card-primary {
  background:
    linear-gradient(180deg, rgba(243, 255, 248, 0.98) 0%, rgba(231, 248, 238, 0.94) 100%);
  border-color: #c6ead4;
}

.quick-action-icon {
  position: relative;
  z-index: 1;
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #2f8f5b;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(34, 197, 94, 0.08);
}

.quick-action-title,
.quick-action-desc {
  position: relative;
  z-index: 1;
}

.quick-action-title {
  margin-top: 18rpx;
}

.home-group-card {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 252, 248, 0.96) 100%);
}

.home-group-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.home-group-name {
  min-width: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.home-members-card .member-row {
  background: linear-gradient(180deg, #fbfdfb 0%, #f5fbf7 100%);
}

.member-meta,
.field-value,
.group-value,
.home-group-name {
  word-break: break-all;
}
