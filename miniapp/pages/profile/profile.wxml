<view class="page-shell with-bottom-nav">
  <view class="panel-card profile-hero-card">
    <view class="profile-hero-top">
      <view>
        <view class="hero-title">{{form.avatar_emoji}} {{form.nickname || '清饮用户'}}</view>
        <view class="hero-subtitle">把自己的资料、统计和群组状态放在一起看清楚。</view>
      </view>
      <view class="status-chip {{auth && auth.bound ? '' : 'neutral'}}">
        {{auth && auth.bound ? '已绑定微信小程序' : '未绑定'}}
      </view>
    </view>
    <view wx:if="{{stats}}" class="stats-grid profile-stats-grid">
      <view class="stat-item">
        <view class="stat-label">戒酒总天数</view>
        <view class="stat-value">{{stats.sober_days}}</view>
      </view>
      <view class="stat-item">
        <view class="stat-label">连续打卡</view>
        <view class="stat-value">{{stats.streak_days}}</view>
      </view>
      <view class="stat-item">
        <view class="stat-label">节省金额</view>
        <view class="stat-value small">¥{{stats.saved_amount}}</view>
      </view>
    </view>
    <view class="inline-button-row">
      <button class="secondary-button" bindtap="handleRefresh" loading="{{loading}}">刷新数据</button>
      <button wx:if="{{group}}" class="secondary-button" bindtap="handleOpenGroup">前往挑战</button>
    </view>
  </view>

  <view wx:if="{{group}}" class="panel-card">
    <view class="section-title">当前监督群组</view>
    <view class="group-row">
      <text class="group-label">群组名称</text>
      <text class="group-value">{{group.name}}</text>
    </view>
    <view class="group-row">
      <text class="group-label">邀请码</text>
      <view class="right-actions">
        <text class="group-value">{{group.invite_code}}</text>
        <button class="ghost-button" bindtap="handleCopyInviteCode">复制</button>
      </view>
    </view>
    <view class="group-row">
      <text class="group-label">我的角色</text>
      <text class="group-value">{{group.viewer_role === 'owner' ? '群主' : '成员'}}</text>
    </view>
    <view class="group-row">
      <text class="group-label">群组人数</text>
      <text class="group-value">{{members.length}} 人</text>
    </view>
  </view>

  <view wx:if="{{!group && !loading}}" class="panel-card">
    <view class="section-title">当前监督群组</view>
    <view class="muted-text">你还没有加入监督群组，可以去挑战页创建或输入邀请码加入。</view>
    <view class="actions-row">
      <button class="secondary-button" bindtap="handleOpenGroup">前往挑战页</button>
    </view>
  </view>

  <view class="panel-card">
    <view class="section-title">迁移 Web 端账号</view>
    <view class="muted-text">
      如果你已经在 Web 版清饮里打过卡或加入过监督群组，可以在 Web 端“我的”页生成迁移码，再回到这里完成一次绑定。
    </view>
    <view wx:if="{{transferMessage}}" class="status-chip" style="margin-top: 18rpx;">{{transferMessage}}</view>
    <view class="form-item" style="margin-top: 20rpx;">
      <text class="form-label">迁移码</text>
      <input
        class="form-input"
        value="{{transferCodeInput}}"
        maxlength="12"
        placeholder="输入 6 位迁移码，没有可留空"
        bindinput="handleTransferCodeInput"
      />
    </view>
    <view class="inline-button-row">
      <button class="secondary-button" bindtap="handlePasteTransferCode">从剪贴板粘贴</button>
      <button class="secondary-button" loading="{{bindingTransfer}}" bindtap="handleClaimTransferCode">绑定迁移码</button>
    </view>
  </view>

  <view class="panel-card form-card">
    <view class="section-title">编辑清饮资料</view>
    <view wx:if="{{error}}" class="error-text">{{error}}</view>

    <view class="form-item">
      <text class="form-label">昵称</text>
      <input
        class="form-input"
        value="{{form.nickname}}"
        data-field="nickname"
        maxlength="20"
        placeholder="请输入昵称"
        bindinput="handleInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">头像表情</text>
      <input
        class="form-input"
        value="{{form.avatar_emoji}}"
        data-field="avatar_emoji"
        maxlength="4"
        placeholder="例如 🌿"
        bindinput="handleInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">戒酒开始日</text>
      <picker mode="date" value="{{form.sober_start_date}}" bindchange="handleDateChange">
        <view class="form-picker">{{form.sober_start_date || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">每日预算</text>
      <input
        class="form-input"
        type="digit"
        value="{{form.daily_budget}}"
        data-field="daily_budget"
        placeholder="请输入每日饮酒预算"
        bindinput="handleInput"
      />
      <view class="form-hint">节省金额会按累计签到次数乘以这里的预算计算。</view>
    </view>

    <view class="actions-row">
      <button class="primary-button" loading="{{saving}}" bindtap="handleSubmit">保存资料</button>
    </view>
  </view>
</view>

<bottom-nav current="profile" />
