.feed-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.feed-card {
  margin-bottom: 0;
}

.feed-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feed-card-body {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #1f2937;
}
